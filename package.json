{
  "name": "cutout",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.1.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-agent-capabilities.mjs && node scripts/validate-product-skills.mjs && tsc -b && vite build && node scripts/check-frontend-bundle.mjs",
    "lint": "oxlint",
    "cutout": "node scripts/cutout.mjs",
    "cutout:mcp": "node scripts/cutout-mcp.mjs",
    "agent:validate": "node scripts/validate-agent-capabilities.mjs && node scripts/validate-product-skills.mjs && node scripts/validate-codex-plugin.mjs",
    "plugin:build": "node scripts/build-codex-plugin.mjs",
    "plugin:validate": "node scripts/validate-codex-plugin.mjs",
    "brand:sync": "node scripts/brand-assets.mjs sync",
    "brand:check": "node scripts/brand-assets.mjs check",
    "test:adapters": "vitest run scripts/cutout-adapters.test.ts",
    "test:integration-smoke": "vitest run scripts/integration-smoke.test.ts src/production-readiness/runtime.test.ts",
    "test:update-artifacts": "vitest run scripts/update-artifacts.test.ts",
    "update:generate": "node scripts/update-artifacts.mjs generate",
    "update:validate": "node scripts/update-artifacts.mjs validate",
    "integration:smoke": "node scripts/integration-smoke.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "i18n:extract": "lingui extract",
    "i18n:extract:clean": "lingui extract --clean",
    "i18n:compile": "lingui compile",
    "i18n:ci": "lingui extract --clean && git diff --exit-code src/locales"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.92",
    "@ai-sdk/gateway": "^3.0.142",
    "@ai-sdk/google": "^3.0.88",
    "@ai-sdk/openai": "^3.0.80",
    "@fontsource-variable/geist": "^5.2.9",
    "@lingui/core": "6.4.0",
    "@lingui/react": "6.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "~2",
    "@tauri-apps/plugin-fs": "~2",
    "@tauri-apps/plugin-os": "~2",
    "@tauri-apps/plugin-store": "~2",
    "@xyflow/react": "^12.11.1",
    "ai": "^6.0.218",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-sha256": "0.10.1",
    "lucide-react": "^1.22.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.25.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "6.4.0",
    "@lingui/cli": "6.4.0",
    "@lingui/conf": "6.4.0",
    "@lingui/format-po": "6.4.0",
    "@lingui/vite-plugin": "6.4.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
