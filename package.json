{
  "name": "asset-cutout-studio",
  "version": "0.1.0",
  "description": "Desktop app for splitting a white-background asset sheet into transparent PNG files.",
  "author": "Leishi AI Native Team",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg",
    "dist:mac:arm64": "electron-builder --mac dmg --arm64",
    "dist:mac:x64": "electron-builder --mac dmg --x64"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.leishi.asset-cutout-studio",
    "productName": "Asset Cutout Studio",
    "copyright": "Copyright © 2026",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": "dmg",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
