{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Grants only the native metadata, event and settings commands used by the main window.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:app:allow-version",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "os:allow-locale",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-save"
  ]
}
